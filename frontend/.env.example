# ─────────────────────────────────────────────────────────────────
# VAULTSNAKE Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# ── NextAuth ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ─────────────────────────────────────────────────
# From console.cloud.google.com → APIs & Services → Credentials
# Add http://localhost:3000/api/auth/callback/google to Authorized redirect URIs
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Backend API ──────────────────────────────────────────────────
# Local dev: point to local FastAPI server
NEXT_PUBLIC_API_URL=http://localhost:8000

# Vercel production: backend is served at /_/backend on the same domain
# NEXT_PUBLIC_API_URL=https://your-app.vercel.app/_/backend
