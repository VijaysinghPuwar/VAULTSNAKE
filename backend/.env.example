# ─────────────────────────────────────────────────────────────────
# VAULTSNAKE Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
APP_ENV=development
# Set to "production" when deploying

# ── JWT ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Google OAuth ─────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Vault Encryption ─────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_ENCRYPTION_KEY=your-fernet-encryption-key-base64-encoded

# ── Database ─────────────────────────────────────────────────────
# SQLite for local dev (default):
DATABASE_URL=sqlite:///./vaultsnake.db

# PostgreSQL for production (uncomment and fill in):
# DATABASE_URL=postgresql://user:password@localhost:5432/vaultsnake

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Admin Bootstrap ──────────────────────────────────────────────
# First user with this email gets auto-promoted to admin on first login
ADMIN_EMAIL=your-admin-email@gmail.com
